# Execution stays dry-run by default. Do not set live behavior in early versions.
TRADING_BOT_MODE=dry_run
ENABLE_LIVE_TRADING=false

# Placeholder broker credentials only. Real values belong in .env, which is git-ignored.
TASTYTRADE_USERNAME=
TASTYTRADE_PASSWORD=
TASTYTRADE_ACCOUNT_NUMBER=
TASTYTRADE_IS_TEST=true

# Optional local settings.
ASSUMED_EQUITY=2000
